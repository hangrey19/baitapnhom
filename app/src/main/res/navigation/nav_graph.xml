<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <!-- ==================== HOME ==================== -->
    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.baitapnhom.ui.home.HomeFragment"
        android:label="Trang chủ"
        tools:layout="@layout/fragment_home">

        <action
            android:id="@+id/action_homeFragment_to_productDetailFragment"
            app:destination="@id/productDetailFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />

        <action
            android:id="@+id/action_homeFragment_to_productListFragment"
            app:destination="@id/productListFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <!-- ==================== PRODUCT LIST ==================== -->
    <fragment
        android:id="@+id/productListFragment"
        android:name="com.example.baitapnhom.ui.product.ProductListFragment"
        android:label="Sản phẩm"
        tools:layout="@layout/fragment_product_list">

        <argument
            android:name="category_id"
            android:defaultValue="0"
            app:argType="integer" />

        <action
            android:id="@+id/action_productListFragment_to_productDetailFragment"
            app:destination="@id/productDetailFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <!-- ==================== PRODUCT DETAIL ==================== -->
    <fragment
        android:id="@+id/productDetailFragment"
        android:name="com.example.baitapnhom.ui.product.ProductDetailFragment"
        android:label="Chi tiết sản phẩm"
        tools:layout="@layout/fragment_product_detail">

        <argument
            android:name="product_id"
            android:defaultValue="0"
            app:argType="integer" />

        <action
            android:id="@+id/action_productDetailFragment_to_cartFragment"
            app:destination="@id/cartFragment" />

        <action
            android:id="@+id/action_productDetailFragment_to_reviewFragment"
            app:destination="@id/reviewFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <!-- ==================== CART ==================== -->
    <fragment
        android:id="@+id/cartFragment"
        android:name="com.example.baitapnhom.ui.cart.CartFragment"
        android:label="Giỏ hàng"
        tools:layout="@layout/fragment_cart">

        <action
            android:id="@+id/action_cartFragment_to_checkoutFragment"
            app:destination="@id/checkoutFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <!-- ==================== CHECKOUT ==================== -->
    <fragment
        android:id="@+id/checkoutFragment"
        android:name="com.example.baitapnhom.ui.order.CheckoutFragment"
        android:label="Thanh toán"
        tools:layout="@layout/fragment_checkout">

        <action
            android:id="@+id/action_checkoutFragment_to_paymentFragment"
            app:destination="@id/paymentFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popUpTo="@id/cartFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- ==================== PAYMENT SUCCESS ==================== -->
    <fragment
        android:id="@+id/paymentFragment"
        android:name="com.example.baitapnhom.ui.order.PaymentFragment"
        android:label="Đặt hàng thành công"
        tools:layout="@layout/fragment_payment">

        <argument
            android:name="order_id"
            android:defaultValue="0"
            app:argType="integer" />

        <action
            android:id="@+id/action_paymentFragment_to_orderHistoryFragment"
            app:destination="@id/orderHistoryFragment"
            app:popUpTo="@id/homeFragment"
            app:popUpToInclusive="false" />
    </fragment>

    <!-- ==================== ORDER HISTORY ==================== -->
    <fragment
        android:id="@+id/orderHistoryFragment"
        android:name="com.example.baitapnhom.ui.order.OrderHistoryFragment"
        android:label="Đơn hàng"
        tools:layout="@layout/fragment_order_history">

        <action
            android:id="@+id/action_orderHistoryFragment_to_orderDetailFragment"
            app:destination="@id/orderDetailFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <!-- ==================== ORDER DETAIL ==================== -->
    <fragment
        android:id="@+id/orderDetailFragment"
        android:name="com.example.baitapnhom.ui.order.OrderDetailFragment"
        android:label="Chi tiết đơn hàng"
        tools:layout="@layout/fragment_order_detail">

        <argument
            android:name="order_id"
            android:defaultValue="0"
            app:argType="integer" />
    </fragment>

    <!-- ==================== CATEGORY ==================== -->
    <fragment
        android:id="@+id/categoryFragment"
        android:name="com.example.baitapnhom.ui.category.CategoryFragment"
        android:label="Danh mục"
        tools:layout="@layout/fragment_category">

        <action
            android:id="@+id/action_categoryFragment_to_productListFragment"
            app:destination="@id/productListFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <!-- ==================== WISHLIST ==================== -->
    <fragment
        android:id="@+id/wishlistFragment"
        android:name="com.example.baitapnhom.ui.wishlist.WishlistFragment"
        android:label="Yêu thích"
        tools:layout="@layout/fragment_wishlist">

        <action
            android:id="@+id/action_wishlistFragment_to_productDetailFragment"
            app:destination="@id/productDetailFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <!-- ==================== PROFILE ==================== -->
    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.baitapnhom.ui.profile.ProfileFragment"
        android:label="Tài khoản"
        tools:layout="@layout/fragment_profile">

        <action
            android:id="@+id/action_profileFragment_to_orderHistoryFragment"
            app:destination="@id/orderHistoryFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <!-- ==================== NOTIFICATION ==================== -->
    <fragment
        android:id="@+id/notificationFragment"
        android:name="com.example.baitapnhom.ui.notification.NotificationFragment"
        android:label="Thông báo"
        tools:layout="@layout/fragment_notification" />

    <!-- ==================== REVIEW ==================== -->
    <fragment
        android:id="@+id/reviewFragment"
        android:name="com.example.baitapnhom.ui.review.ReviewFragment"
        android:label="Viết đánh giá"
        tools:layout="@layout/fragment_review">

        <argument
            android:name="product_id"
            android:defaultValue="0"
            app:argType="integer" />
    </fragment>

</navigation>