<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:endColor="#FFF3E0"
                android:startColor="#FFF9F1" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <item android:gravity="center" android:top="12dp">
        <shape android:shape="rectangle">
            <size android:width="56dp" android:height="80dp" />
            <solid android:color="#FFCC80" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <item android:gravity="center" android:top="18dp">
        <shape android:shape="rectangle">
            <size android:width="46dp" android:height="58dp" />
            <gradient
                android:angle="270"
                android:endColor="#F57C00"
                android:startColor="#FFB74D" />
            <corners android:radius="10dp" />
        </shape>
    </item>
    <item android:gravity="center_horizontal|top" android:top="6dp">
        <shape android:shape="rectangle">
            <size android:width="8dp" android:height="20dp" />
            <solid android:color="#81C784" />
            <corners android:radius="3dp" />
        </shape>
    </item>
</layer-list>
