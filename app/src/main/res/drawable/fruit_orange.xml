<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:endColor="#FFF3E0"
                android:startColor="#FFF8EE" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <item android:gravity="center" android:top="16dp">
        <shape android:shape="oval">
            <size android:width="76dp" android:height="76dp" />
            <gradient
                android:angle="270"
                android:endColor="#F57C00"
                android:startColor="#FFA726" />
        </shape>
    </item>
    <item android:gravity="center_horizontal|top" android:top="18dp" android:left="18dp">
        <rotate android:fromDegrees="-18">
            <shape android:shape="rectangle">
                <size android:width="18dp" android:height="10dp" />
                <solid android:color="#43A047" />
                <corners android:radius="10dp" />
            </shape>
        </rotate>
    </item>
</layer-list>
