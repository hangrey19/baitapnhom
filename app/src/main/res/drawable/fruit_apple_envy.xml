<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:endColor="#FFE0E0"
                android:startColor="#FFF5F5" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <item android:gravity="center" android:top="18dp">
        <shape android:shape="oval">
            <size android:width="74dp" android:height="74dp" />
            <gradient
                android:angle="270"
                android:endColor="#C62828"
                android:startColor="#EF5350" />
        </shape>
    </item>
    <item android:gravity="center_horizontal|top" android:top="12dp" android:left="18dp">
        <rotate android:fromDegrees="-28">
            <shape android:shape="rectangle">
                <size android:width="18dp" android:height="10dp" />
                <solid android:color="#66BB6A" />
                <corners android:radius="10dp" />
            </shape>
        </rotate>
    </item>
    <item android:gravity="center_horizontal|top" android:top="18dp">
        <shape android:shape="rectangle">
            <size android:width="4dp" android:height="14dp" />
            <solid android:color="#6D4C41" />
            <corners android:radius="2dp" />
        </shape>
    </item>
</layer-list>
